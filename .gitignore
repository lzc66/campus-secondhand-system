
**.gitignore**
```gitignore
# Java / Maven
target/
*.class
*.jar
*.war
*.ear
*.log

# Maven wrapper
!.mvn/wrapper/maven-wrapper.properties
!.mvn/wrapper/maven-wrapper.jar

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Runtime files
storage/
uploads/
tmp/
temp/
logs/
*.pid

# IDE
.idea/
.vscode/
*.iml
.project
.classpath
.settings/

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Env / local config
.env
.env.*
*.local
application-local.yml
application-prod.yml
application-secret.yml

# npm / pnpm / yarn logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Coverage / reports
coverage/
frontend/coverage/

# Misc
*.swp
*.swo
*.bak
